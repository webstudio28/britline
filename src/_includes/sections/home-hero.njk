<section class="relative min-h-[90vh] flex items-center overflow-hidden text-white" id="hero">
  <div class="absolute inset-0 z-0">
    <img src="{{ ('/assets/images/' + home.hero.image) | url }}" alt="" class="w-full h-full object-cover" fetchpriority="high">
    <div class="absolute inset-0 bg-black/65" aria-hidden="true"></div>
  </div>
  <div class="container-custom relative z-10 section-padding w-full">
    <div class="flex flex-col gap-10 items-start">
      <div class="text-left max-w-xl">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">{{ home.hero.headline }}</h1>
        <p class="text-lg text-white/90 {% if home.hero.subparagraph %}mb-3{% else %}mb-6{% endif %}">{{ home.hero.paragraph }}</p>
        {% if home.hero.subparagraph %}
        <p class="text-base text-white/80 mb-6">{{ home.hero.subparagraph }}</p>
        {% endif %}
        <div class="flex flex-wrap items-center gap-3">
          <button type="button" onclick="typeof initMyOrder === 'function' && initMyOrder();" class="inline-flex w-full md:w-auto items-center justify-center rounded-2xl bg-brand-blue text-white font-semibold px-20 py-4 border-2 border-gray-500 shadow-[0_10px_30px_rgba(0,0,0,0.45)] hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-blue/50">{{ home.hero.booking.buttonLabel }}</button>
          <a href="https://wa.me/{{ site.contact.whatsapp }}" target="_blank" rel="noopener noreferrer" class="hidden md:inline-flex items-center gap-2 bg-white/85 backdrop-blur-md rounded-2xl px-5 py-3 shadow-lg border border-white/30 text-[#128C7E] hover:bg-white/95 w-fit" aria-label="Chat on WhatsApp">
            {% from "macros/ui.njk" import icon %}
            {{ icon('whatsapp') }}
            <span class="font-semibold">WhatsApp</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
